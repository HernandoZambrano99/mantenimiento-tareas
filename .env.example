# Copy to `.env` for local runs and fill in real values. `.env` is gitignored.
# Render reads its values from the dashboard / render.yaml, not from this file.

# --- Runtime ------------------------------------------------------------------
# Spring profile. `dev` = colored console logs; `docker`/`prod` = JSON logs.
SPRING_PROFILES_ACTIVE=dev
# Render injects PORT automatically; locally leave unset to use server.port=8081.
# PORT=10000

# --- Database -----------------------------------------------------------------
# Local docker-compose default:
DB_URL=jdbc:postgresql://localhost:5432/mantenimiento
DB_USERNAME=postgres
DB_PASSWORD=admin

# Neon example (uncomment and replace placeholders):
# DB_URL=jdbc:postgresql://ep-cool-darkness-12345.us-east-2.aws.neon.tech/mantenimiento?sslmode=require&channel_binding=require
# DB_USERNAME=neon_user
# DB_PASSWORD=<copied-from-neon-dashboard>

# Hikari pool sizing (Neon free tier ≈ 5 concurrent connections is safe).
DB_POOL_SIZE=5
DB_POOL_MIN_IDLE=1

# --- JWT ----------------------------------------------------------------------
# Must be at least 256 bits (32 chars) for HS256. Generate with:
#   openssl rand -base64 48
JWT_SECRET=ChangeMeToASecretAtLeast256BitsLongForHS256_ChangeMeNow
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# --- Bootstrap admin ----------------------------------------------------------
# If ADMIN_PASSWORD is empty/unset, a random one is generated and logged on the
# first boot. Set it explicitly for production.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- CORS ---------------------------------------------------------------------
# Comma-separated origin list (no trailing slash). Add your frontend origin
# (e.g. https://myapp.vercel.app) when deploying.
CORS_ORIGINS=http://localhost:3000
